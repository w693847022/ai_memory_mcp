# MCP 服务器配置
# 传输模式: stdio, sse, streamable-http
MCP_TRANSPORT=streamable-http

# 服务器监听地址（Docker 内部）
MCP_HOST=0.0.0.0

# 服务器端口
MCP_PORT=8000

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
MCP_LOG_LEVEL=INFO

# 存储目录（数据持久化路径）
MCP_STORAGE_DIR=/app/.project_memory_ai

# 用户配置 - 使用宿主机用户避免文件权限问题
UID=1002
GID=1002
